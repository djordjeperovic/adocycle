{
  "name": "adocycle",
  "version": "0.1.9",
  "description": "Azure DevOps CLI for querying your assigned work items",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "adocycle": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.20.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "azure-devops",
    "cli",
    "typescript"
  ],
  "author": "Djordje Perovic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djordjeperovic/adocycle.git"
  },
  "bugs": {
    "url": "https://github.com/djordjeperovic/adocycle/issues"
  },
  "homepage": "https://github.com/djordjeperovic/adocycle#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "azure-devops-node-api": "^15.1.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "env-paths": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
